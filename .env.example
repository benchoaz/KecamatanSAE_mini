APP_NAME="KecamatanSAE Dashboard"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://kecamatanbesuk.my.id

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database Configuration (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=dashboard_kecamatan
DB_USERNAME=user
DB_PASSWORD=password_aman_anda

# Cache & Session
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration (Optional)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@kecamatanbesuk.my.id"
MAIL_FROM_NAME="${APP_NAME}"

# WAHA WhatsApp API Configuration (EXTERNAL VPS)
# Masukkan URL publik WAHA Anda di sini
WAHA_API_URL=https://waha.vps-lain.com
WAHA_API_KEY=key_rahasia_waha_anda
WAHA_SESSION=default
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=password_dashboard_waha

# n8n Workflow Configuration (EXTERNAL VPS)
# Masukkan URL publik n8n Webhook Anda di sini
N8N_REPLY_WEBHOOK_URL=https://n8n.vps-lain.com/webhook/whatsapp-besuk

# API Security Configuration
# Digunakan untuk validasi komunikasi antar layanan
WHATSAPP_API_TOKEN=token_rahasia_waha_anda
DASHBOARD_API_TOKEN=token_rahasia_dashboard_anda
